FLASK_ENV=development
SECRET_KEY=change-this-secret-at-least-32-bytes
JWT_SECRET=change-this-jwt-secret-at-least-32-bytes
DATABASE_URL=sqlite:///training_portal.db
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=8
RATE_LIMITS=300 per minute,5000 per hour
RATELIMIT_STORAGE_URI=memory://
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEV_SHOW_OTP=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=training.neighshopglobal@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=Neighshop Global Training
